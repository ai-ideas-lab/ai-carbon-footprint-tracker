generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  carbonRecords CarbonRecord[]
  achievements Achievement[]
  socialGroups SocialGroup[]
  userPreferences UserPreference[]
  userChallenges UserChallenge[]
  
  @@map("users")
}

model CarbonRecord {
  id          String   @id @default(cuid())
  userId      String
  category    String
  type        String
  amount      Float
  unit        String
  source      String?
  description String?
  carbonEmission Float // kg CO2e
  location    String?
  date        DateTime @default(now())
  analyzed    Boolean  @default(false)
  aiInsights  String?
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("carbon_records")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  icon        String?
  points      Int      @default(10)
  unlockedAt  DateTime @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("achievements")
}

model SocialGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  // Relations
  members User[]
  challenges GroupChallenge[]
  
  @@map("social_groups")
}

model GroupChallenge {
  id          String   @id @default(cuid())
  groupId     String
  title       String
  description String
  targetValue Float
  unit        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  
  // Relations
  group SocialGroup @relation(fields: [groupId], references: [id])
  userChallenges UserChallenge[]
  
  @@map("group_challenges")
}

model UserChallenge {
  id           String    @id @default(cuid())
  userId       String
  challengeId  String
  progress     Float     @default(0)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  
  // Relations
  user      User       @relation(fields: [userId], references: [id])
  challenge GroupChallenge @relation(fields: [challengeId], references: [id])
  
  @@map("user_challenges")
}

model UserPreference {
  id                   String   @id @default(cuid())
  userId               String
  preferredCategories  String   // JSON string of preferred carbon categories
  notificationsEnabled Boolean  @default(true)
  dailyGoal            Float?   // daily carbon reduction goal
  language             String   @default("zh-CN")
  currency             String   @default("CNY")
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_preferences")
}

// Carbon categories as string constants (to be validated in application)
// Valid values: TRANSPORTATION, FOOD, ENERGY, SHOPPING, HOUSING, WASTE, OTHER

// Carbon types as string constants (to be validated in application)  
// Valid values: DIRECT, INDIRECT, OFFSET